{
  "name": "notdone-monorepo",
  "version": "0.1.0",
  "description": "Proof-of-completion for AI agents",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "check": "pnpm docs:check && pnpm integrations:check && pnpm typecheck && pnpm test && pnpm test:plugins && pnpm test:conformance",
    "docs:check": "node scripts/check-readmes.mjs",
    "integrations:check": "node scripts/check-integrations.mjs",
    "pack:release": "node scripts/pack-release.mjs",
    "pack:verify": "node scripts/verify-release-packages.mjs",
    "test": "pnpm --recursive --if-present test",
    "test:conformance": "node --test tests/runtime-conformance.test.mjs",
    "test:plugins": "node --test tests/*-plugin.test.mjs",
    "typecheck": "pnpm --recursive --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
