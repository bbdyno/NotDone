{
  "name": "notdone",
  "version": "0.1.0",
  "description": "Command-line interface for NotDone proof verification",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/bbdyno/NotDone#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbdyno/NotDone.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/bbdyno/NotDone/issues"
  },
  "keywords": [
    "ai-agent",
    "proof-of-completion",
    "verification",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "notdone": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.mjs && tsup && node ../../scripts/copy-package-assets.mjs dist",
    "test": "vitest run src",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@notdone/core": "workspace:*",
    "@notdone/protocol": "workspace:*"
  }
}
