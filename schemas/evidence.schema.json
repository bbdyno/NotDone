{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:notdone:schema:evidence:v1",
  "title": "NotDone Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "runId",
    "claimIds",
    "type",
    "trust",
    "capturedAt",
    "digest",
    "producer"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "$ref": "#/$defs/identifier"
    },
    "runId": {
      "$ref": "#/$defs/identifier"
    },
    "claimIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "checkId": {
      "$ref": "#/$defs/identifier"
    },
    "type": {
      "enum": [
        "command",
        "file",
        "git-diff",
        "log",
        "screenshot",
        "external-state",
        "manual"
      ]
    },
    "trust": {
      "enum": [
        "self-reported",
        "observed",
        "executed",
        "reproduced",
        "attested"
      ]
    },
    "capturedAt": {
      "type": "string",
      "format": "date-time"
    },
    "digest": {
      "$ref": "#/$defs/sha256"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime"
      ],
      "properties": {
        "runtime": {
          "enum": [
            "notdone",
            "claude-code",
            "codex",
            "gemini-cli",
            "human",
            "external"
          ]
        },
        "runtimeVersion": {
          "type": "string",
          "maxLength": 128
        },
        "sessionId": {
          "type": "string",
          "maxLength": 256
        },
        "actorId": {
          "type": "string",
          "maxLength": 256
        }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mediaType",
        "size"
      ],
      "properties": {
        "mediaType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "path": {
          "type": "string",
          "maxLength": 4096
        },
        "inline": {
          "type": "string"
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "cwd",
        "exitCode",
        "durationMs"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1,
          "maxLength": 10000
        },
        "cwd": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "exitCode": {
          "type": "integer"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "stdoutDigest": {
          "$ref": "#/$defs/sha256"
        },
        "stderrDigest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "redactions": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 256
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "command"
          }
        }
      },
      "then": {
        "required": [
          "command"
        ],
        "properties": {
          "command": true
        }
      }
    }
  ]
}
