{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:notdone:schema:proof-packet:v1",
  "title": "NotDone Proof Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "createdAt",
    "contract",
    "contractDigest",
    "evidence",
    "result",
    "runtimeCapabilities",
    "integrity"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "runId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "contract": {
      "$ref": "urn:notdone:schema:task-contract:v1"
    },
    "contractDigest": {
      "$ref": "#/$defs/sha256"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "maxLength": 4096
        },
        "head": {
          "type": "string",
          "maxLength": 256
        },
        "dirty": {
          "type": "boolean"
        },
        "diffDigest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "urn:notdone:schema:evidence:v1"
      }
    },
    "result": {
      "$ref": "urn:notdone:schema:verification-result:v1"
    },
    "runtimeCapabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "runtime",
          "capabilities"
        ],
        "properties": {
          "runtime": {
            "enum": [
              "claude-code",
              "codex",
              "gemini-cli"
            ]
          },
          "runtimeVersion": {
            "type": "string",
            "maxLength": 128
          },
          "capabilities": {
            "type": "object",
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "gaps": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 1000
            }
          }
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "digest"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
