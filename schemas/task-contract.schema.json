{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:notdone:schema:task-contract:v1",
  "title": "NotDone Task Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "createdAt",
    "mode",
    "claims"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "$ref": "#/$defs/identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "maxLength": 10000
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "frozenAt": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "enum": [
        "explicit",
        "derived"
      ]
    },
    "baseRevision": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "user",
            "issue",
            "file",
            "api"
          ]
        },
        "reference": {
          "type": "string",
          "maxLength": 2048
        }
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "statement",
        "required",
        "checks"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "statement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "required": {
          "type": "boolean"
        },
        "minimumTrust": {
          "enum": [
            "observed",
            "executed",
            "reproduced",
            "attested"
          ],
          "default": "executed"
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/commandCheck"
              },
              {
                "$ref": "#/$defs/fileCheck"
              },
              {
                "$ref": "#/$defs/gitDiffCheck"
              },
              {
                "$ref": "#/$defs/manualCheck"
              }
            ]
          }
        }
      }
    },
    "checkBase": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "commandCheck": {
      "allOf": [
        {
          "$ref": "#/$defs/checkBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type",
            "command",
            "expect"
          ],
          "properties": {
            "id": {
              "$ref": "#/$defs/identifier"
            },
            "type": {
              "const": "command"
            },
            "description": {
              "type": "string",
              "maxLength": 1000
            },
            "command": {
              "type": "string",
              "minLength": 1,
              "maxLength": 10000
            },
            "cwd": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096
            },
            "timeoutMs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3600000,
              "default": 60000
            },
            "expect": {
              "type": "object",
              "additionalProperties": false,
              "minProperties": 1,
              "properties": {
                "exitCode": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 255
                },
                "stdoutIncludes": {
                  "type": "string",
                  "maxLength": 10000
                },
                "stderrIncludes": {
                  "type": "string",
                  "maxLength": 10000
                }
              }
            }
          }
        }
      ]
    },
    "fileCheck": {
      "allOf": [
        {
          "$ref": "#/$defs/checkBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type",
            "path",
            "expect"
          ],
          "properties": {
            "id": {
              "$ref": "#/$defs/identifier"
            },
            "type": {
              "const": "file"
            },
            "description": {
              "type": "string",
              "maxLength": 1000
            },
            "path": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096
            },
            "expect": {
              "type": "object",
              "additionalProperties": false,
              "minProperties": 1,
              "properties": {
                "exists": {
                  "type": "boolean"
                },
                "sha256": {
                  "$ref": "#/$defs/sha256"
                },
                "contains": {
                  "type": "string",
                  "maxLength": 10000
                }
              }
            }
          }
        }
      ]
    },
    "gitDiffCheck": {
      "allOf": [
        {
          "$ref": "#/$defs/checkBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type"
          ],
          "properties": {
            "id": {
              "$ref": "#/$defs/identifier"
            },
            "type": {
              "const": "git-diff"
            },
            "description": {
              "type": "string",
              "maxLength": 1000
            },
            "allowedPaths": {
              "$ref": "#/$defs/pathPatterns"
            },
            "requiredPaths": {
              "$ref": "#/$defs/pathPatterns"
            },
            "forbiddenPaths": {
              "$ref": "#/$defs/pathPatterns"
            }
          }
        }
      ]
    },
    "manualCheck": {
      "allOf": [
        {
          "$ref": "#/$defs/checkBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type",
            "prompt"
          ],
          "properties": {
            "id": {
              "$ref": "#/$defs/identifier"
            },
            "type": {
              "const": "manual"
            },
            "description": {
              "type": "string",
              "maxLength": 1000
            },
            "prompt": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000
            }
          }
        }
      ]
    },
    "pathPatterns": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
