{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:notdone:schema:verification-result:v1",
  "title": "NotDone Verification Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "contractDigest",
    "status",
    "evaluatedAt",
    "claims"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "runId": {
      "$ref": "#/$defs/identifier"
    },
    "contractDigest": {
      "$ref": "#/$defs/sha256"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claimId",
          "status",
          "evidenceIds",
          "checkResults"
        ],
        "properties": {
          "claimId": {
            "$ref": "#/$defs/identifier"
          },
          "status": {
            "$ref": "#/$defs/status"
          },
          "reason": {
            "type": "string",
            "maxLength": 4000
          },
          "evidenceIds": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/identifier"
            }
          },
          "checkResults": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "checkId",
                "status"
              ],
              "properties": {
                "checkId": {
                  "$ref": "#/$defs/identifier"
                },
                "status": {
                  "$ref": "#/$defs/status"
                },
                "evidenceId": {
                  "$ref": "#/$defs/identifier"
                },
                "reason": {
                  "type": "string",
                  "maxLength": 4000
                }
              }
            }
          }
        }
      }
    },
    "proofGaps": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 4000
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "status": {
      "enum": [
        "verified",
        "unverified",
        "blocked",
        "failed"
      ]
    }
  }
}
